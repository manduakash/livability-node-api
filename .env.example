# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
TZ=Asia/Kolkata

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ---------------------------------------------------------------------------
# MySQL (matches the existing `livility` database / livility.sql dump)
# ---------------------------------------------------------------------------

DB_HOST=13.205.64.19
DB_USER=admin
DB_PORT=3306
DB_PASSWORD=YourPassword123
DB_NAME=livility

# ---------------------------------------------------------------------------
# EnggEnv (water level + AAQ sensors)
# https://apis.enggenv.com
# ---------------------------------------------------------------------------
ENGGENV_BASE_URL=https://apis.enggenv.com
ENGGENV_WATER_DEVICE_ID=GWR02310
ENGGENV_AAQ_APP_KEY=Ymlzd2FuYXRoZ0BlcHAud29yazoyMDI0LTAzLTE5

# ---------------------------------------------------------------------------
# West Bengal Pollution Control Board (EMIS AQI station feed)
# ---------------------------------------------------------------------------
WBPCB_BASE_URL=http://emis.wbpcb.gov.in/airquality/stndtlsdata
WBPCB_DEFAULT_STATION_ID=01116

# ---------------------------------------------------------------------------
# Paribesh noise API
# ---------------------------------------------------------------------------
PARIBESH_BASE_URL=https://api.paribesh.wtlprojects.com/api/v1/admin/get_noise_data_by_name

# ---------------------------------------------------------------------------
# Distronix ANMS (noise) / AQI per-property feeds
# Each property has its own subdomain + bearer-style "Authorization" token.
# Add one block per property you need to poll. The keys below
# (e.g. SWANCOURT) are referenced from src/config/properties.js.
# ---------------------------------------------------------------------------
DISTRONIX_SWANCOURT_REAL_ESTATE_ID=1
DISTRONIX_SWANCOURT_ANMS_URL=https://anms.swancourt.distronix.in/swancourt/getlatestdata
DISTRONIX_SWANCOURT_ANMS_TOKEN=barrier wzgCJKDz8d/6CHvqn0iM3JCaNr8zQF/Fy1uCcP0N1SA=
DISTRONIX_SWANCOURT_AQI_URL=https://aqi.swancourt.distronix.in/swancourt/getlatestdata
DISTRONIX_SWANCOURT_AQI_TOKEN=Bearer wzgCJKDz8d/6CHvqn0iM3JCaNr8zQF/Fy1uCcP0N1SA=

