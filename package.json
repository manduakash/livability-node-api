{
  "name": "livability-third-party-api",
  "version": "1.0.0",
  "description": "Express.js + Drizzle ORM re-implementation of the third-party API integrations from the legacy Livibility PHP project (EnggEnv, WBPCB, Paribesh, Distronix ANMS/AQI).",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0"
  }
}
